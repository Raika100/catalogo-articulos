---
import { products } from "../../data/products.ts";
import { WHATSAPP_NUMBER, SITE_URL, SITE_NAME } from "../../config/site.ts";

export const prerender = true;

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const productUrl = `${SITE_URL}/producto/${product.slug}`;
const message = `Hola me interesa este articulo, esta disponible?\n\n${productUrl}`;
const whatsappHref = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{product.name} | {SITE_NAME}</title>

    <meta name="description" content={product.description} />
    <meta property="og:title" content={`${product.name} | ${SITE_NAME}`} />
    <meta property="og:description" content={product.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={productUrl} />
    <meta property="og:image" content={product.images[0]} />

    <style>
      :root {
        --surface: rgba(255, 255, 255, 0.9);
        --text: #18181b;
        --muted: #666b75;
        --border: rgba(24, 24, 27, 0.08);
        --shadow: 0 18px 40px rgba(17, 24, 39, 0.08);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: Inter, Arial, sans-serif;
        background: linear-gradient(180deg, #f8f6f1 0%, #f1ede6 100%);
        color: var(--text);
      }

      .container {
        width: min(1200px, calc(100% - 32px));
        margin: 0 auto;
      }

      .header {
        position: sticky;
        top: 0;
        backdrop-filter: blur(12px);
        background: rgba(246, 244, 239, 0.72);
        border-bottom: 1px solid rgba(24, 24, 27, 0.05);
        z-index: 10;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 0;
      }

      .brand {
        font-weight: 800;
        letter-spacing: 0.03em;
        text-decoration: none;
        color: inherit;
      }

      .back-link {
        display: inline-block;
        margin: 28px 0 18px;
        color: var(--muted);
        text-decoration: none;
      }

      .product-layout {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 22px;
        padding-bottom: 50px;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .gallery-main img {
        width: 100%;
        aspect-ratio: 4 / 5;
        object-fit: cover;
        display: block;
      }

      .thumbs {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
        padding: 14px;
      }

      .thumb-button {
        border: 0;
        background: transparent;
        padding: 0;
        cursor: pointer;
      }

      .thumbs img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border-radius: 14px;
        display: block;
      }

      .info { padding: 24px; }

      .kicker {
        color: var(--muted);
        font-size: 0.95rem;
        margin-bottom: 10px;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.05;
      }

      .price {
        margin-top: 16px;
        font-size: 1.5rem;
        font-weight: 800;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 16px;
      }

      .meta span {
        background: #f0ece4;
        color: var(--muted);
        border-radius: 999px;
        padding: 8px 10px;
        font-size: 0.82rem;
      }

      .description {
        margin-top: 20px;
        line-height: 1.7;
        color: var(--muted);
      }

      .details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 22px;
      }

      .detail-box {
        background: white;
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 14px;
      }

      .detail-box strong {
        display: block;
        font-size: 0.82rem;
        color: var(--muted);
        margin-bottom: 6px;
      }

      .actions {
        display: flex;
        gap: 10px;
        margin-top: 22px;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-block;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid var(--border);
        text-decoration: none;
        font-weight: 600;
      }

      .btn-primary {
        background: #111827;
        color: white;
      }

      .btn-ghost {
        background: rgba(255, 255, 255, 0.8);
        color: #111827;
      }

      .status-available { color: #166534; }
      .status-sold { color: #9f1239; }

      @media (max-width: 900px) {
        .product-layout { grid-template-columns: 1fr; }
      }

      @media (max-width: 640px) {
        .thumbs { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .details { grid-template-columns: 1fr; }
      }
    </style>
  </head>

  <body>
    <header class="header">
      <div class="container header-inner">
        <a class="brand" href="/">{SITE_NAME}</a>
      </div>
    </header>

    <main class="container">
      <a class="back-link" href="/">← Volver al catálogo</a>

      <section class="product-layout">
        <div class="card">
          <div class="gallery-main">
            <img id="mainImage" src={product.images[0]} alt={product.name} />
          </div>

          {product.images.length > 1 && (
            <div class="thumbs">
              {product.images.map((img) => (
                <button class="thumb-button" type="button" data-image={img}>
                  <img src={img} alt={product.name} />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="card info">
          <div class="kicker">{product.category} · {product.type}</div>

          <h1>{product.name}</h1>

          <div class="price">${product.price} MXN</div>

          <div class="meta">
            <span class={product.available ? "status-available" : "status-sold"}>
              {product.available ? "Disponible" : "Vendido"}
            </span>
            <span>Talla: {product.size}</span>
            <span>Marca: {product.brand}</span>
          </div>

          <p class="description">{product.description}</p>

          <div class="details">
            <div class="detail-box">
              <strong>Categoría</strong>
              <span>{product.category}</span>
            </div>

            <div class="detail-box">
              <strong>Tipo</strong>
              <span>{product.type}</span>
            </div>

            <div class="detail-box">
              <strong>Talla</strong>
              <span>{product.size}</span>
            </div>

            <div class="detail-box">
              <strong>Estado</strong>
              <span>{product.available ? "Disponible" : "Vendido"}</span>
            </div>
          </div>

          <div class="actions">
            <a
              class="btn btn-primary"
              href={whatsappHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              Me interesa
            </a>

            <a class="btn btn-ghost" href="/">
              Volver
            </a>
          </div>
        </div>
      </section>
    </main>

    <script>
      const mainImage = document.getElementById("mainImage");
      const thumbButtons = document.querySelectorAll(".thumb-button");

      thumbButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const nextImage = button.getAttribute("data-image");
          if (mainImage && nextImage) {
            mainImage.setAttribute("src", nextImage);
          }
        });
      });
    </script>
  </body>
</html>