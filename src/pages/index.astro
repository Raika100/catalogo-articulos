---
import { products } from "../data/products.ts";
import { WHATSAPP_NUMBER, SITE_URL, SITE_NAME } from "../config/site.ts";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{SITE_NAME}</title>
    <style>
      :root {
        --bg: #f6f4ef;
        --surface: rgba(255, 255, 255, 0.88);
        --text: #18181b;
        --muted: #666b75;
        --border: rgba(24, 24, 27, 0.08);
        --shadow: 0 18px 40px rgba(17, 24, 39, 0.08);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: Inter, Arial, sans-serif;
        background: linear-gradient(180deg, #f8f6f1 0%, #f1ede6 100%);
        color: var(--text);
      }

      .container {
        width: min(1200px, calc(100% - 32px));
        margin: 0 auto;
      }

      .header {
        position: sticky;
        top: 0;
        backdrop-filter: blur(12px);
        background: rgba(246, 244, 239, 0.72);
        border-bottom: 1px solid rgba(24, 24, 27, 0.05);
        z-index: 10;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 0;
      }

      .brand {
        font-weight: 800;
        letter-spacing: 0.03em;
      }

      .cta {
        display: inline-block;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: white;
        box-shadow: var(--shadow);
        text-decoration: none;
        color: inherit;
      }

      .hero {
        padding: 36px 0 20px;
      }

      .hero-card {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.65));
        border: 1px solid rgba(255, 255, 255, 0.75);
        box-shadow: var(--shadow);
        border-radius: 30px;
        padding: 32px;
      }

      .promo-banner {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        margin-bottom: 18px;
        border-radius: 999px;
        background: linear-gradient(135deg, #c1121f 0%, #e5383b 100%);
        color: white;
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        box-shadow: 0 14px 30px rgba(193, 18, 31, 0.22);
      }

      .promo-banner strong {
        font-weight: 800;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 1;
      }

      .hero p {
        max-width: 720px;
        color: var(--muted);
        line-height: 1.65;
        font-size: 1.02rem;
      }

      .filters {
        padding: 4px 0 18px;
      }

      .filters-card {
        display: grid;
        grid-template-columns: 1.3fr 1fr 1fr;
        gap: 12px;
        padding: 18px;
        background: rgba(255, 255, 255, 0.84);
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }

      .input,
      .select,
      .checkbox-wrap {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: white;
        padding: 14px 16px;
        font-size: 0.95rem;
      }

      .checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .checkbox-wrap input { margin: 0; }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        padding: 12px 0 48px;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: var(--shadow);
      }

      .image-link {
        display: block;
        text-decoration: none;
        color: inherit;
      }

      .image-wrap {
        position: relative;
        aspect-ratio: 4 / 5;
        overflow: hidden;
        background: #f7f4ee;
      }

      .image-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transform: scale(1.04);
        transition: transform 0.25s ease;
      }

      .image-link:hover .image-wrap img {
        transform: scale(1.07);
      }

      .badge {
        position: absolute;
        top: 14px;
        left: 14px;
        border-radius: 999px;
        padding: 8px 12px;
        color: white;
        font-size: 0.8rem;
        font-weight: 700;
        z-index: 1;
        pointer-events: none;
      }

      .badge.available { background: rgba(31, 122, 79, 0.92); }
      .badge.sold { background: rgba(159, 18, 57, 0.92); }

      .card-body { padding: 18px; }

      .top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
      }

      .title {
        margin: 0;
        font-size: 1rem;
        line-height: 1.35;
      }

      .price {
        font-weight: 800;
        white-space: nowrap;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
      }

      .meta span {
        background: #f0ece4;
        color: var(--muted);
        border-radius: 999px;
        padding: 8px 10px;
        font-size: 0.82rem;
      }

      .actions {
        display: flex;
        gap: 10px;
        margin-top: 16px;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid var(--border);
        text-decoration: none;
        font-weight: 600;
        line-height: 1;
        transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
      }

      .btn:hover {
        transform: translateY(-1px);
      }

      .btn-icon {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }

      .btn-primary {
        background: #25d366;
        color: white;
        border-color: #25d366;
      }

      .btn-primary:hover {
        box-shadow: 0 10px 24px rgba(37, 211, 102, 0.22);
      }

      .btn-ghost {
        background: rgba(255, 255, 255, 0.88);
        color: #111827;
      }

      .btn-ghost:hover {
        box-shadow: 0 10px 24px rgba(17, 24, 39, 0.08);
      }

      .empty-state {
        display: none;
        margin-top: 10px;
        padding: 24px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid var(--border);
        text-align: center;
        color: var(--muted);
        box-shadow: var(--shadow);
      }

      @media (max-width: 900px) {
        .filters-card { grid-template-columns: 1fr 1fr; }
        .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      }

      @media (max-width: 640px) {
        .grid,
        .filters-card { grid-template-columns: 1fr; }

        .hero-card { padding: 24px; }

        .promo-banner {
          display: flex;
          width: 100%;
          justify-content: center;
          text-align: center;
          border-radius: 18px;
        }
      }
    </style>
  </head>

  <body>
    <header class="header">
      <div class="container header-inner">
        <div class="brand">{SITE_NAME}</div>
        <a class="cta" href="#catalogo">Ver catálogo</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <div class="hero-card">
            <div class="promo-banner">✨ <strong>10% de descuento en tu primer compra</strong></div>
            <h1>Catálogo de artículos</h1>
            <p>
              Explora nuestra selección de ropa, calzado, bolsas y accesorios.
              Todos nuestros artículos son originales y nuevos. Encuentra tus favoritos y contáctanos por WhatsApp.
              Realizamos entregas en Ciudad de México.
            </p>
          </div>
        </div>
      </section>

      <section class="filters">
        <div class="container">
          <div class="filters-card">
            <input
              id="searchInput"
              class="input"
              type="text"
              placeholder="Buscar por nombre, marca o tipo"
            />

            <select id="categoryFilter" class="select">
              <option value="">Todas las categorías</option>
              <option value="Hombre">Hombre</option>
              <option value="Mujer">Mujer</option>
            </select>

            <label class="checkbox-wrap">
              <input id="availableOnly" type="checkbox" />
              <span>Solo disponibles</span>
            </label>
          </div>
        </div>
      </section>

      <section id="catalogo">
        <div class="container">
          <div class="grid" id="productsGrid">
            {products.map((product) => {
              const productUrl = `${SITE_URL}/producto/${product.slug}`;
              const message = `Hola, me interesa este artículo, ¿Sigue disponible?\n\n${productUrl}`;
              const whatsappHref = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;

              return (
                <article
                  class="card product-card"
                  data-category={product.category}
                  data-available={product.available ? "true" : "false"}
                  data-search={`${product.name} ${product.brand} ${product.type}`.toLowerCase()}
                >
                  <a
                    class="image-link"
                    href={product.images[0]}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Abrir imagen completa de ${product.name}`}
                  >
                    <div class="image-wrap">
                      <img src={product.images[0]} alt={product.name} />
                      <span class={`badge ${product.available ? "available" : "sold"}`}>
                        {product.available ? "Disponible" : "Vendido"}
                      </span>
                    </div>
                  </a>

                  <div class="card-body">
                    <div class="top">
                      <h2 class="title">{product.name}</h2>
                      <div class="price">${product.price} MXN</div>
                    </div>

                    <div class="meta">
                      <span>{product.category}</span>
                      <span>{product.type}</span>
                      <span>{product.size}</span>
                    </div>

                    <div class="actions">
                      <a
                        class="btn btn-primary"
                        href={whatsappHref}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg
                          class="btn-icon"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                          fill="currentColor"
                        >
                          <path d="M20.52 3.48A11.86 11.86 0 0 0 12.07 0C5.5 0 .16 5.34.16 11.91c0 2.1.55 4.16 1.59 5.98L0 24l6.29-1.65a11.9 11.9 0 0 0 5.78 1.47h.01c6.57 0 11.91-5.34 11.91-11.91 0-3.18-1.24-6.17-3.47-8.43ZM12.08 21.8h-.01a9.9 9.9 0 0 1-5.05-1.39l-.36-.21-3.73.98 1-3.64-.24-.37a9.86 9.86 0 0 1-1.52-5.26c0-5.46 4.45-9.91 9.92-9.91 2.65 0 5.13 1.03 6.99 2.9a9.83 9.83 0 0 1 2.9 7c0 5.46-4.45 9.9-9.9 9.9Zm5.44-7.42c-.3-.15-1.77-.88-2.04-.98-.27-.1-.46-.15-.66.15s-.76.98-.93 1.18c-.17.2-.34.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.04-.17-.3-.02-.46.13-.61.13-.13.3-.34.44-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.66-1.6-.9-2.18-.24-.58-.49-.5-.66-.51h-.56c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.87 1.22 3.07c.15.2 2.09 3.2 5.07 4.49.71.31 1.26.49 1.7.63.71.23 1.36.2 1.87.12.57-.08 1.77-.72 2.02-1.42.25-.69.25-1.29.17-1.42-.07-.12-.27-.2-.56-.35Z" />
                        </svg>
                        <span>Me interesa</span>
                      </a>

                      <a class="btn btn-ghost" href={`/producto/${product.slug}`}>
                        <svg
                          class="btn-icon"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-2h6l2 2h4a2 2 0 0 1 2 2z"></path>
                          <circle cx="12" cy="13" r="4"></circle>
                        </svg>
                        <span>Ver más</span>
                      </a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

          <div id="emptyState" class="empty-state">
            No se encontraron artículos con esos filtros.
          </div>
        </div>
      </section>
    </main>

    <script>
      const searchInput = document.getElementById("searchInput");
      const categoryFilter = document.getElementById("categoryFilter");
      const availableOnly = document.getElementById("availableOnly");
      const cards = document.querySelectorAll(".product-card");
      const emptyState = document.getElementById("emptyState");

      const applyFilters = () => {
        const text = (searchInput?.value || "").toLowerCase().trim();
        const category = categoryFilter?.value || "";
        const onlyAvailable = availableOnly?.checked || false;

        let visible = 0;

        cards.forEach((card) => {
          const matchesText = !text || card.dataset.search?.includes(text);
          const matchesCategory = !category || card.dataset.category === category;
          const matchesAvailability = !onlyAvailable || card.dataset.available === "true";

          const show = matchesText && matchesCategory && matchesAvailability;
          card.style.display = show ? "" : "none";

          if (show) visible += 1;
        });

        if (emptyState) {
          emptyState.style.display = visible === 0 ? "block" : "none";
        }
      };

      searchInput?.addEventListener("input", applyFilters);
      categoryFilter?.addEventListener("change", applyFilters);
      availableOnly?.addEventListener("change", applyFilters);
    </script>
  </body>
</html>